# .env.dreamware.example
# Copy to .env on the server and fill in real values.
# NEVER commit .env to Git.
#
# This file documents Dreamware-specific env vars on top of upstream defaults.
# See upstream docs for the full list of AnythingLLM env vars.

# ── Core ──────────────────────────────────────────────────────────────────────
SERVER_PORT=3001
STORAGE_DIR=/app/server/storage

# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME

# ── Environment ───────────────────────────────────────────────────────────────
# "test" or "production"
APP_ENV=test

# ── LLM Provider (pick one) ───────────────────────────────────────────────────
OPEN_AI_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# AZURE_OPENAI_ENDPOINT=https://...
# AZURE_OPENAI_KEY=...

# ── Embedding ─────────────────────────────────────────────────────────────────
# EMBEDDING_ENGINE=openai
# OPEN_AI_KEY is reused by default for embeddings

# ── Vector DB ─────────────────────────────────────────────────────────────────
# Default: LanceDB (file-based, no extra setup)
# VECTOR_DB=lancedb

# ── Dreamware Custom ──────────────────────────────────────────────────────────
# Add any Dreamware-specific env vars below
DREAMWARE_FORK=true
